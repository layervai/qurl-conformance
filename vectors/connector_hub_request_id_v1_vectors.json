  "artifact": "qurl-connector-hub-request-id-v1-vectors",
  "schema_version": 1,
  "description": "Byte-exact private replay-key derivation contract for authenticated assignment LST handled by Connector Hub workers. The SDK supplies only a per-logical-operation request_nonce; Hub derives hub_request_id after NHP authentication and sends it only to the separately permissioned Connector Authority IssueAssignment, RefreshAssignment, or IssueCredentialRecovery operation.",
  "contract": {
