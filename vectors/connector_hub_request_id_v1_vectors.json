    "domain_ascii": "layerv:qurl:connector-hub-request-id:v1",
    "domain_suffix_hex": "00",
    "frame_encoding": "u8_field_tag_then_u16be_byte_length_then_value",
    "environment_tag_hex": "01",
    "operation_tag_hex": "02",
    "peer_tag_hex": "03",
    "nonce_tag_hex": "04",
    "field_order": [
      "environment",
      "operation",
      "authenticated_peer_public_key",
      "request_nonce"
    ],
    "environment_pattern": "^[a-z](?:[a-z0-9-]{0,30}[a-z0-9])?$",
    "environment_min_bytes": 1,
    "environment_max_bytes": 32,
    "environment_normalization": "none",
    "operations": [
      "IssueAssignment",
      "RefreshAssignment",
      "IssueCredentialRecovery"
    ],
    "peer_decoded_bytes": 32,
    "peer_fixture_encoding": "canonical_base64_std_padded",
    "peer_hash_encoding": "raw_32_bytes",
    "nonce_decoded_bytes": 32,
    "nonce_fixture_encoding": "canonical_base64url_unpadded",
    "nonce_hash_encoding": "raw_32_bytes",
    "excluded_inputs": [
      "nhp_send_timestamp",
      "nhp_transaction_id",
      "exact_body_digest",
      "source_address",
      "hub_request_id_in_public_body"
    ]
  },
