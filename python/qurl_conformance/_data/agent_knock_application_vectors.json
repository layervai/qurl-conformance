      "reply_type": 2,
      "request_counter": "42",
      "reply_counter": "42",
      "body_json": "{\"errCode\":\"0\",\"resHost\":{\"tunnel-conformance-01\":\"frps.sandbox.example:7000\"},\"opnTime\":900,\"agentAddr\":\"203.0.113.9:49152\",\"acTokens\":{\"tunnel-conformance-01\":\"ac-token-conformance-01\"}}",
      "outcome": "success"
    },
    {
